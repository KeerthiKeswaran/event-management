{
  "Subject": "Ticket Booking Confirmed: IIT Madras Tech \u0026 AI Hackathon",
  "Body": "\u003C!DOCTYPE html\u003E\n\u003Chtml\u003E\n\u003Chead\u003E\n  \u003Cmeta charset=\u0022utf-8\u0022 /\u003E\n  \u003Cstyle\u003E\n    body {\n      font-family: \u0027Segoe UI\u0027, Arial, sans-serif;\n      background-color: #ffffff;\n      color: #000000;\n      margin: 0;\n      padding: 0;\n    }\n    .container {\n      max-width: 480px;\n      margin: 40px auto;\n      background-color: #ffffff;\n      border: 3px solid #000000;\n      border-radius: 0px;\n      overflow: hidden;\n    }\n    .header {\n      background-color: #ffffff;\n      padding: 24px;\n      text-align: center;\n      border-bottom: 3px solid #000000;\n    }\n    .header img {\n      max-width: 220px;\n      height: auto;\n      display: block;\n      margin: 0 auto;\n    }\n    .body {\n      padding: 40px;\n    }\n    .body p {\n      color: #000000;\n      font-size: 16px;\n      line-height: 1.6;\n      margin: 0 0 20px;\n    }\n    .info-box {\n      background-color: #000000;\n      border: 2px solid #8B0000;\n      padding: 24px;\n      margin: 30px 0;\n      color: #ffffff;\n    }\n    .info-title {\n      font-size: 18px;\n      font-weight: 800;\n      text-transform: uppercase;\n      margin-bottom: 12px;\n      border-bottom: 1px solid #8B0000;\n      padding-bottom: 4px;\n      color: #ffffff;\n    }\n    .info-item {\n      font-size: 14px;\n      margin-bottom: 8px;\n      line-height: 1.4;\n    }\n    .info-label {\n      font-weight: bold;\n      color: #ffcccc;\n    }\n    .note {\n      font-size: 13px;\n      color: #000000;\n      margin-top: 20px;\n      border-left: 3px solid #8B0000;\n      padding-left: 12px;\n    }\n    .footer {\n      background-color: #000000;\n      color: #ffffff;\n      padding: 20px;\n      text-align: center;\n      font-size: 12px;\n      border-top: 3px solid #000000;\n      letter-spacing: 1px;\n    }\n  \u003C/style\u003E\n\u003C/head\u003E\n\u003Cbody\u003E\n  \u003Cdiv class=\u0022container\u0022\u003E\n    \u003Cdiv class=\u0022header\u0022\u003E\n      \u003Cimg src=\u0022cid:logo.png\u0022 alt=\u0022GetMyEvents Logo\u0022 /\u003E\n    \u003C/div\u003E\n    \u003Cdiv class=\u0022body\u0022\u003E\n      \u003Cp\u003EHello,\u003C/p\u003E\n      \u003Cp\u003EThank you for your ticket purchase! Your booking has been successfully confirmed.\u003C/p\u003E\n      \n      \u003Cdiv class=\u0022info-box\u0022\u003E\n        \u003Cdiv class=\u0022info-title\u0022\u003EBooking Confirmation\u003C/div\u003E\n        \u003Cdiv class=\u0022info-item\u0022\u003E\u003Cspan class=\u0022info-label\u0022\u003EBooking ID:\u003C/span\u003E #20002\u003C/div\u003E\n        \u003Cdiv class=\u0022info-item\u0022\u003E\u003Cspan class=\u0022info-label\u0022\u003EEvent:\u003C/span\u003E IIT Madras Tech \u0026 AI Hackathon\u003C/div\u003E\n        \u003Cdiv class=\u0022info-item\u0022\u003E\u003Cspan class=\u0022info-label\u0022\u003EAmount Paid:\u003C/span\u003E INR 312.05\u003C/div\u003E\n        \u003Cdiv class=\u0022info-item\u0022\u003E\u003Cspan class=\u0022info-label\u0022\u003ETickets:\u003C/span\u003E 1x VIP Access\u003C/div\u003E\n      \u003C/div\u003E\n\n      \u003Cp class=\u0022note\u0022\u003EYour digital ticket containing a QR code for check-in has been generated. Please keep your QR code ready upon arrival at the venue.\u003C/p\u003E\n      \u003Cdiv style=\u0022text-align: center; margin-top: 20px;\u0022\u003E\n        \u003Cimg src=\u0022https://quickchart.io/qr?text=fc2a4501b7224d438b1d94217dbbf5d3\u0026size=200\u0022 alt=\u0022Booking QR Code\u0022 style=\u0022max-width: 200px; border: 2px solid #000;\u0022 /\u003E\n      \u003C/div\u003E\n    \u003C/div\u003E\n    \u003Cdiv class=\u0022footer\u0022\u003E\n      \u0026copy; 2026 GetMyEvents. All rights reserved.\n    \u003C/div\u003E\n  \u003C/div\u003E\n\u003C/body\u003E\n\u003C/html\u003E\n"
}